{
  "name": "swagger-ai",
  "version": "1.0.0",
  "description": "Turn your Swagger/OpenAPI specs into LLM-optimized AI Skill documentation",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "swagger",
    "openapi",
    "llm",
    "ai",
    "documentation",
    "skill",
    "llms.txt",
    "ai-seo",
    "markdown",
    "api"
  ],
  "author": "yash_sahu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sahuyash1103/swagger-ai.git"
  },
  "homepage": "https://github.com/sahuyash1103/swagger-ai#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "openapi-types": "^12.1.3"
  }
}
